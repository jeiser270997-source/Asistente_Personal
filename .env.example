# ── API Keys (multi-proveedor) ──
# Consigue tus API keys en cada plataforma
OPENROUTER_API_KEY=sk-or-v1-...  # https://openrouter.ai/keys
GROQ_API_KEY=gsk_...              # https://console.groq.com/keys
CEREBRAS_API_KEY=csk-...          # https://console.cerebras.ai/
NVIDIA_API_KEY=nvapi-...          # https://build.nvidia.com/
GEMINI_API_KEY=AIza...            # https://aistudio.google.com/
SAMBANOVA_API_KEY=...             # https://cloud.sambanova.ai/
COHERE_API_KEY=...                # https://dashboard.cohere.com/
CLOUDFLARE_API_KEY=cfut_...       # https://workers.cloudflare.com/
HUGGINGFACE_API_KEY=hf_...        # https://huggingface.co/settings/tokens
MISTRAL_API_KEY=...               # https://console.mistral.ai/

# ── GitHub (para WheelSaver scraper) ──
# Necesario para que WheelSaver pueda scrapear repos de GitHub
GITHUB_TOKEN=github_pat_...       # https://github.com/settings/tokens

# ── Telegram ──
TELEGRAM_BOT_TOKEN=tu_token
TELEGRAM_CHAT_ID=tu_chat_id

# ── SENA Moodle ──
SENA_MOODLE_URL=https://zajuna.sena.edu.co
SENA_MOODLE_USER=tu_usuario
SENA_MOODLE_PASS=tu_contraseña
SENA_MOODLE_COURSE_ID=121953

# ── ADB Config ──
ADB_PATH=C:\Users\dev\AppData\Local\Android\Sdk\platform-tools\adb.exe

# ── DIAN MUISCA ──
DIAN_USER=tu_cedula
DIAN_PASS=tu_contraseña

# ── Apprise (notificaciones multi-canal) ──
# Apprise es el mecanismo principal de notificaciones.
# Envía a Telegram, Discord, Slack, email, etc.
# Instalación: docker run -d -p 8000:8000 caronc/apprise
# APPRISE_URL=http://localhost:8000

# ── Storage Driver (json | sqlite) ──
# sqlite = runtime stores leen/escriben SQLite (con migración lazy desde JSON)
# json   = backward-compatible, lee/escribe archivos JSON directamente
# Al ponerlo sqlite, las stores migran datos desde JSON automáticamente
STORAGE_DRIVER=sqlite

# ── Nivel de automatización de postulaciones Computrabajo ──
# 1 = solo notificar (default)
# 2 = abrir URL en el navegador
# 3 = auto-postular con Playwright (completo)
APPLY_LEVEL=3

# ── Opcionales ──
LOCAL_REPOS_DIR=E:\PROYECTOS\Proyectos_GitHub
EMAIL_SCAN_HOURS=6
INBOX_DIR=C:\Users\dev\Desktop\INBOX_JEISER
