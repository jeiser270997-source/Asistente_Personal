# =============================================================================
# LIFE OS — Variables de Entorno (Julio 2026)
# Copia este archivo como .env y completa los valores obligatorios
# =============================================================================
# NOTA: Sistema Single-Tenant personal. No compartas este archivo.

# ── Identidad del Usuario ─────────────────────────────────────────────────
USER_CC=               # Cédula de Ciudadanía (ej: 1019156838)
USER_NAME=             # Nombre completo
USER_PLATE=            # Placa del vehículo (ej: KEW496)
USER_PHONE=            # Número de celular
USER_EMAIL=            # Correo principal

# ── Telegram (OBLIGATORIO para notificaciones) ────────────────────────────
TELEGRAM_BOT_TOKEN=    # Token del bot (de @BotFather)
TELEGRAM_CHAT_ID=      # ID numérico del chat autorizado

# ── SENA — Moodle Zajuna ──────────────────────────────────────────────────
SENA_MOODLE_USER=      # Número de documento (usuario SENA)
SENA_MOODLE_PASS=      # Contraseña de Moodle SENA
SENA_MOODLE_COURSE_ID= # ID del curso (default: 121953)

# ── SENA — Betowa ─────────────────────────────────────────────────────────
BETOWA_TOKEN=          # Token JWT de Betowa (de localStorage)
BETOWA_PASS=           # Contraseña Betowa (fallback)

# ── Tránsito ──────────────────────────────────────────────────────────────
ITAGUI_USER=           # Correo portal Itagüí
ITAGUI_PASS=           # Contraseña portal Itagüí
MEDELLIN_USER=         # Documento portal Medellín (default: USER_CC)
MEDELLIN_PASS=         # Contraseña portal Medellín

# ── DIAN MUISCA ───────────────────────────────────────────────────────────
DIAN_USER=             # NIT o CC (default: USER_CC)
DIAN_PASS=             # Contraseña MUISCA

# ── Computrabajo ──────────────────────────────────────────────────────────
COMPUTRABAJO_EMAIL=    # Correo registrado
COMPUTRABAJO_PASS=     # Contraseña
APPLY_LEVEL=           # 1=notificar, 2=semi-auto, 3=full-auto (default: 1)

# ── Google APIs ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=      # Client ID de Google Cloud Console
GOOGLE_CLIENT_SECRET=  # Client Secret
DISABLE_CALENDAR_SYNC= # "true" para deshabilitar (default: true)

# ── LLM / OmniRoute (recomendado) ─────────────────────────────────────────
# Gateway local: https://github.com/diegosouzapw/OmniRoute  (default :20128)
# Las API free se configuran EN OmniRoute; LifeOS solo apunta al gateway.
OMNIROUTE_URL=http://localhost:20128
OMNIROUTE_API_KEY=omniroute
OMNIROUTE_MODEL=auto/cheap
OMNIROUTE_MODEL_CODING=auto/coding
# OMNIROUTE_ALLOW_SENSITIVE=true   # solo si aceptas reenviar PII a free tiers vía OmniRoute
# LLM_SKIP_DIRECT=true             # default implícito si OmniRoute está up
#
# Wake 5am / correo: NO necesitan LLM. Email LLM solo con EMAIL_USE_LLM=true
EMAIL_USE_LLM=false
# Gmail fail-safe (default): solo etiquetas, NUNCA trash, inbox no se vacía
# EMAIL_INBOX_ZERO=true   # saca de bandeja al etiquetar (agresivo)
# EMAIL_ALLOW_TRASH=true  # permite papelera (recuperable 30d) — no recomendado
#
# Fallback directo (solo si OmniRoute caído):
GROQ_API_KEY=
OPENROUTER_API_KEY=
SAMBANOVA_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_API_KEY=
LITELLM_URL=http://localhost:4000

# ── Notificaciones multicanal ─────────────────────────────────────────────
APPRISE_URL=           # Apprise (default: http://localhost:8000)
NTFY_URL=              # ntfy push (default: http://localhost:8080)
NTFY_TOPIC=            # Topic ntfy (default: lifeos)
NTFY_TOKEN=            # Token ntfy (opcional)

# ── APIs Externas ─────────────────────────────────────────────────────────
TOMTOM_API_KEY=        # TomTom Traffic (gratis, developer.tomtom.com)
CRAWL4AI_URL=          # crawl4ai (default: http://localhost:11235)
MEMOS_URL=             # Memos notas (default: http://localhost:5230)
MEMOS_TOKEN=           # Token Memos (opcional)

# ── Dashboard Web ─────────────────────────────────────────────────────────
DASHBOARD_TOKEN=       # Token auth para el dashboard
IS_DOCKER=             # "true" dentro de Docker (default: false)

# ── Storage ───────────────────────────────────────────────────────────────
LIFEOS_DB_PATH=        # Ruta a memoria_hipocampo.db
STORAGE_DRIVER=        # Driver (default: sqlite)

# ── Email ─────────────────────────────────────────────────────────────────
EMAIL_SCAN_HOURS=      # Ventana escaneo en horas (default: 24)

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=             # debug | info | warn | error (default: info)

# ── Archivos Locales ──────────────────────────────────────────────────────
LOCAL_REPOS_DIR=       # Directorio de repos locales
INBOX_DIR=             # Directorio inbox local
RESPALDO_BASE=         # Base para respaldos
ADB_PATH=              # Ruta a ADB (alarmas Android)
